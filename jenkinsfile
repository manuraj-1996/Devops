pipeline {
    agent { label 'slave' }

    tools {
        jdk 'jdk17'
        maven 'maven3'
    }

    environment {
        MAVEN_OPTS = '-Xmx1024m'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/manuraj-1996/Devops.git',
                    credentialsId: 'New'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Deploy to Artifactory') {
            steps {
                configFileProvider([
                    configFile(fileId: 'my_settings', variable: 'MAVEN_SETTINGS')
                ]) {
                    sh 'mvn deploy -s $MAVEN_SETTINGS'
                }
            }
        }
    }

    post {
        success {
            echo 'Build and Deployment Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}
